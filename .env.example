# Database
DATABASE_URL=postgresql://user:password@localhost:5432/prode
TEST_DATABASE_URL=postgresql://prode:prode123@127.0.0.1:5432/prode

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Google OAuth
# Google OAuth requires all three settings below.
# For local development, these should point to your local backend.
# For production, they should point to your deployed backend.
# Google OAuth is disabled if any of these are missing or empty.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match the exact public Google OAuth redirect URI.
# Production should normally be: https://YOUR_DOMAIN/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Frontend Google OAuth (optional)
# Set to your Google Client ID to enable the Google login button on the frontend.
# This is separate from GOOGLE_CLIENT_SECRET to prevent exposing secrets in the browser.
# If not set, the Google login button will not appear.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Site URL
# Public frontend origin used for CORS and post-auth redirects.
SITE_URL=http://localhost:5173

# Transactional email / password reset delivery
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=Prode
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Frontend analytics (optional)
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_PROVIDER=none
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Results importer (optional)
# Server-side API key for football-data.org. When set, the admin endpoint
# POST /api/tournaments/:id/import-results pulls FIFA World Cup standings
# and knockout winners and never overwrites existing results. When unset
# the endpoint replies 503 and the cron script logs and exits cleanly.
RESULTS_IMPORT_API_KEY=
# Defaults to "WC" (FIFA World Cup). Override only if you point the
# importer at a different football-data.org competition.
RESULTS_IMPORT_COMPETITION_CODE=
# Credentials and target used by scripts/import-results.cjs (CLI + cron).
# RESULTS_IMPORT_API_KEY above is read by the server, not by the CLI.
RESULTS_IMPORT_API_BASE_URL=http://localhost:3001
RESULTS_IMPORT_ADMIN_EMAIL=
RESULTS_IMPORT_ADMIN_PASSWORD=
RESULTS_IMPORT_TOURNAMENT_ID=
RESULTS_IMPORT_TOURNAMENT_NAME=FIFA World Cup 2026
